{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "80000"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(xargs:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(cut:*)",
      "Bash(tee:*)",
      "Bash(chmod:*)",
      "Bash(for:*)",
      "Bash(bash:*)",
      "Bash(python3:*)",
      "Bash(pip3 install:*)",
      "Bash(node -e:*)",
      "Bash(openssl rand:*)",
      "Bash(curl:*)",

      "Bash(npm install:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run lint:fix:*)",
      "Bash(npm run format:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:unit:run:*)",
      "Bash(npm run test:nuxt:run:*)",
      "Bash(npm run check-i18n:*)",
      "Bash(npm run check-translations:*)",
      "Bash(npm run i18n:mark-todo:*)",
      "Bash(npm run app1:docker:dev:logs:*)",
      "Bash(npm run app1:docker:dev:get-lockfile:*)",
      "Bash(npm run app1:help:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(npx nuxi typecheck:*)",
      "Bash(npx nuxt prepare)",
      "Bash(npx prisma:*)",
      "Bash(npx web-push:*)",

      "Bash(node scripts/translation/list-todo-keys.js:*)",
      "Bash(node scripts/translation/apply-translations.js:*)",
      "Bash(node scripts/translation/mark-todo.js:*)",
      "Bash(node scripts/translation/generate-todo-files.js:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git mv:*)",
      "Bash(git config:*)",
      "Bash(git check-ignore:*)",

      "Bash(docker exec:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images:*)",
      "Bash(docker restart:*)",

      "Bash(pkill -f playwright)",
      "Bash(pkill -f chrome-headless-shell)",

      "Edit(.claude/error-logs-monitor.json)",
      "Write(.claude/error-logs-monitor.json)",

      "Bash(bash scripts/check-error-logs.sh:*)",
      "Bash(scripts/check-error-logs.sh:*)",
      "Bash(./scripts/check-error-logs.sh:*)",
      "Bash(bash scripts/trigger-prod-deploy.sh:*)",
      "Bash(scripts/trigger-prod-deploy.sh:*)",
      "Bash(./scripts/trigger-prod-deploy.sh:*)",
      "Bash(bash scripts/update-error-logs-state.sh:*)",
      "Bash(scripts/update-error-logs-state.sh:*)",
      "Bash(./scripts/update-error-logs-state.sh:*)",
      "Skill(check-error-logs)",
      "Skill(check-error-logs:*)",

      "SlashCommand(/lint-fix)",
      "SlashCommand(/run-tests)",
      "SlashCommand(/commit-push)",
      "Skill(lint-fix)",
      "Skill(lint-fix:*)",
      "Skill(run-tests)",
      "Skill(commit-push)",
      "Skill(quality-check)",
      "Skill(i18n-fix)",
      "Skill(i18n-fix:*)",
      "Skill(translate-todos)",
      "Skill(translate-todos:*)",
      "Skill(analyze-codebase)",
      "Skill(analyze-codebase:*)",

      "mcp__nuxt-ui__get-component",
      "mcp__nuxt-ui__get-component-metadata",
      "mcp__nuxt-ui__list-components",
      "mcp__nuxt-ui__search-components-by-category",
      "mcp__jcodemunch__get_repo_outline",
      "mcp__jcodemunch__find_references",

      "WebSearch",
      "WebFetch(domain:ui.nuxt.com)",
      "WebFetch(domain:nuxt.com)",
      "WebFetch(domain:www.prisma.io)",
      "WebFetch(domain:fullcalendar.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:h3.unjs.io)",
      "WebFetch(domain:v1.h3.dev)",
      "WebFetch(domain:lucide.dev)",
      "WebFetch(domain:unpkg.com)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["nuxt", "nuxt-ui", "vitest-runner", "Prisma-Remote"]
}

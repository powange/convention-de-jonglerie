# Base de données MySQL (Flowvent).
# Hors Docker : viser localhost:3307 (port publié par docker-compose.dev.yml).
# En Docker, docker-compose surcharge DATABASE_URL vers le service flowvent-db.
DATABASE_URL="mysql://flowvent_user:flowvent_password@localhost:3307/flowvent_db"

# Identifiants MySQL (utilisés par docker-compose pour créer/servir la base)
MYSQL_ROOT_PASSWORD="rootpassword"
MYSQL_DATABASE="flowvent_db"
MYSQL_USER="flowvent_user"
MYSQL_PASSWORD="flowvent_password"

# Secret de session nuxt-auth-utils (minimum 32 caractères).
# Générer : openssl rand -base64 32
NUXT_SESSION_PASSWORD="change-me-please-with-a-32-chars-minimum-secret"

# --- OAuth Google (bouton « Continuer avec Google ») — optionnel ---
# Le handler /auth/google est fourni par le layer d'auth (layers/auth).
# 1. Crée un client OAuth 2.0 : https://console.cloud.google.com/apis/credentials
# 2. Ajoute l'URI de redirection autorisée correspondant à ton origine d'accès, ex. :
#      http://localhost:3001/auth/google        (accès en localhost)
#      https://dev.event.powange.com/auth/google (accès via le reverse proxy)
# 3. Renseigne les 2 valeurs ci-dessous. Laisse vide pour désactiver le bouton Google.
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""
# Optionnel : forcer l'URI de redirection. Vide = dérivée de l'origine de la requête (recommandé).
# NUXT_OAUTH_GOOGLE_REDIRECT_URL="http://localhost:3001/auth/google"

# URL publique du site (liens dans les emails de vérification / réinitialisation).
NUXT_PUBLIC_SITE_URL="http://localhost:3001"

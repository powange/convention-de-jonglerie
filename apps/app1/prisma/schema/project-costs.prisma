// =============================================================================
// Coûts du projet — Postes de dépense et historique des tarifs
// =============================================================================

enum ProjectExpenseCategory {
  DOMAIN
  HOSTING
  HARDWARE
  ELECTRICITY
  SOFTWARE
  SERVICE
  OTHER
}

enum ProjectExpensePeriod {
  MONTHLY
  YEARLY
  ONE_TIME
}

model ProjectExpense {
  id          Int                    @id @default(autoincrement())
  name        String
  description String?                @db.Text
  category    ProjectExpenseCategory
  icon        String?
  isActive    Boolean                @default(true)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  rates ProjectExpenseRate[]

  @@index([isActive])
  @@index([sortOrder])
}

model ProjectExpenseRate {
  id        Int                  @id @default(autoincrement())
  expenseId Int
  amount    Decimal              @db.Decimal(10, 2)
  currency  String               @default("EUR")
  period    ProjectExpensePeriod
  startDate DateTime
  endDate   DateTime?
  note      String?              @db.Text
  createdAt DateTime             @default(now())

  expense ProjectExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId], map: "idx_project_expense_rate_expense")
  @@index([startDate])
}

// =============================================================================
// Donations café — Configuration Stripe et historique des dons
// =============================================================================

model StripeConfig {
  id            Int      @id @default(autoincrement())
  publicKey     String   @db.Text // Encrypted (AES-256-GCM)
  secretKey     String   @db.Text // Encrypted (AES-256-GCM)
  webhookSecret String   @db.Text // Encrypted (AES-256-GCM)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TimeEstimateConfig {
  id            Int      @id @default(autoincrement())
  fixedHours    Decimal  @db.Decimal(10, 1) // Heures comptabilisées à la date de référence
  referenceDate DateTime // Date à laquelle le compteur fixe est valable
  weeklyHours   Decimal  @db.Decimal(5, 1) // Heures estimées par semaine après la date de référence
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CoffeeDonation {
  id              Int      @id @default(autoincrement())
  stripeSessionId String   @unique
  quantity        Int
  totalCents      Int
  feeCents        Int?
  netCents        Int?
  email           String?
  customerName    String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

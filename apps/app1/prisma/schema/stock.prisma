// Stock matériel : suivi du matériel d'une édition (groupes, objets,
// réservations sur des périodes).

enum StockReservationStatus {
  RESERVED // Réservé (par défaut à la création)
  PICKED_UP // Sorti / pris par le réserveur
  RETURNED // Rendu au stock
  CANCELLED // Annulée
}

model StockGroup {
  id           Int      @id @default(autoincrement())
  editionId    Int
  name         String
  description  String?  @db.Text
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edition Edition     @relation(fields: [editionId], references: [id], onDelete: Cascade)
  items   StockItem[]

  @@index([editionId])
  @@index([editionId, displayOrder])
}

model StockItem {
  id             Int       @id @default(autoincrement())
  stockGroupId   Int
  name           String
  description    String?   @db.Text
  quantity       Int       @default(1) // Nombre d'exemplaires identiques
  notes          String?   @db.Text
  displayOrder   Int       @default(0)
  // Emprunt externe : matériel prêté par quelqu'un d'extérieur à la convention.
  // Si `isExternalLoan` est false, les 3 champs suivants sont ignorés.
  isExternalLoan Boolean   @default(false)
  ownerContact   String?   @db.Text // Texte libre (ex: "Jean Dupont — 06 12 34 56 78")
  returnDueAt    DateTime? // Date prévue de retour au propriétaire
  returnedAt     DateTime? // Date effective du retour. null = pas encore rendu
  // Emplacement de rangement par défaut : où ranger le matériel quand il
  // n'est pas réservé. Au moins l'un des trois doit être renseigné si l'on
  // veut afficher un emplacement (validé côté API, tous peuvent rester null).
  location       String? // Texte libre (ex: "Tente technique B")
  zoneId         Int? // Lien optionnel vers une zone de la carte
  markerId       Int? // Lien optionnel vers un marqueur de la carte
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group        StockGroup         @relation(fields: [stockGroupId], references: [id], onDelete: Cascade)
  zone         EditionZone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  marker       EditionMarker?     @relation(fields: [markerId], references: [id], onDelete: SetNull)
  reservations StockReservation[]

  @@index([stockGroupId])
  @@index([stockGroupId, displayOrder])
  @@index([zoneId])
  @@index([markerId])
}

model StockReservation {
  id               Int                    @id @default(autoincrement())
  stockItemId      Int
  userId           Int // Utilisateur qui a posé la réservation
  startsAt         DateTime
  endsAt           DateTime
  usage            String                 @db.Text // Pourquoi : "Spectacle de feu samedi 22h"
  quantityReserved Int                    @default(1)
  status           StockReservationStatus @default(RESERVED)
  // Emplacement d'utilisation : où le matériel doit être amené pendant la
  // réservation. Différent du rangement (StockItem.location). À la fin de la
  // réservation, le matériel retourne à son emplacement de rangement.
  // Au moins l'un des trois (location/zoneId/markerId) doit être renseigné
  // (validé côté API).
  location         String? // Texte libre (ex: "Scène principale, fond droit")
  zoneId           Int? // Lien optionnel vers une zone de la carte
  markerId         Int? // Lien optionnel vers un marqueur de la carte
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  stockItem StockItem      @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  zone      EditionZone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  marker    EditionMarker? @relation(fields: [markerId], references: [id], onDelete: SetNull)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([userId])
  @@index([zoneId])
  @@index([markerId])
  @@index([stockItemId, startsAt, endsAt])
  @@index([status])
}

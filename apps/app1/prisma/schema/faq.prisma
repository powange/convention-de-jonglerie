// FAQ : questions/réponses paramétrables par les organisateurs sur une édition.
// Chaque entrée peut être publique (visible côté visiteur) ou privée (visible
// uniquement dans la gestion).

model FaqEntry {
  id           Int      @id @default(autoincrement())
  editionId    Int
  question     String   @db.VarChar(500)
  answer       String   @db.Text // Markdown (rendu via markdownToHtml + rehype-sanitize côté client)
  isPublic     Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edition Edition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId])
  @@index([editionId, displayOrder])
  @@index([editionId, isPublic])
}

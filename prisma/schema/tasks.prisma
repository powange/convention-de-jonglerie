// Tâches : organisation interne du travail des organisateurs d'une édition.
// Les tâches sont regroupées dans des TaskGroup pour permettre une
// catégorisation libre (par phase, par équipe, etc.). Chaque tâche peut
// être assignée à un ou plusieurs users (organisateurs ou bénévoles
// ACCEPTED de l'édition).

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

model TaskGroup {
  id           Int      @id @default(autoincrement())
  editionId    Int
  name         String
  description  String?  @db.Text
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edition Edition   @relation(fields: [editionId], references: [id], onDelete: Cascade)
  tasks   Task[]
  tags    TaskTag[]

  @@index([editionId])
  @@index([editionId, displayOrder])
}

model Task {
  id           Int        @id @default(autoincrement())
  taskGroupId  Int
  title        String
  description  String?    @db.Text
  status       TaskStatus @default(TODO)
  deadline     DateTime?
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  group          TaskGroup           @relation(fields: [taskGroupId], references: [id], onDelete: Cascade)
  assignments    TaskAssignment[]
  comments       TaskComment[]
  checklistItems TaskChecklistItem[]
  tagAssignments TaskTagAssignment[]

  @@index([taskGroupId])
  @@index([taskGroupId, displayOrder])
  @@index([status])
}

model TaskAssignment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int
  userId    Int
  content   String    @db.Text
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([taskId, createdAt])
}

// Item de checklist (sous-tâche légère) rattaché à une Task. Permet de
// découper une grosse tâche en items cochables sans dupliquer le cycle de
// statut TODO/IN_PROGRESS/DONE/CANCELLED.
model TaskChecklistItem {
  id           Int      @id @default(autoincrement())
  taskId       Int
  title        String
  done         Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, displayOrder])
}

// Tag/label personnalisé défini au niveau d'un groupe de tâches. Permet de
// catégoriser les tâches d'un groupe (ex: « urgent », « matériel », « à valider
// RH »). Couleur stockée comme nom Tailwind (red, blue, etc.).
model TaskTag {
  id           Int      @id @default(autoincrement())
  taskGroupId  Int
  name         String
  color        String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group       TaskGroup           @relation(fields: [taskGroupId], references: [id], onDelete: Cascade)
  assignments TaskTagAssignment[]

  @@unique([taskGroupId, name])
  @@index([taskGroupId])
  @@index([taskGroupId, displayOrder])
}

// Liaison many-to-many entre Task et TaskTag. Une tâche peut porter 0..N tags.
model TaskTagAssignment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  tagId     Int
  createdAt DateTime @default(now())

  task Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}
